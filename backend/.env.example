PRIVSHIELD_APP_ENV=production
PRIVSHIELD_DATABASE_PATH=data/privshield.db
PRIVSHIELD_CORS_ORIGINS=http://localhost:5173

# 默认关闭，因此启动应用不需要下载或运行模型。
PRIVSHIELD_LLM_ENABLED=false
PRIVSHIELD_LLM_BASE_URL=http://127.0.0.1:8001/v1
PRIVSHIELD_LLM_API_KEY=local-token
PRIVSHIELD_LLM_MODEL=Qwen/Qwen3-14B-AWQ

# GPU 服务器启用；首次启动会从 Hugging Face 下载配置的 NER 权重。
PRIVSHIELD_NER_ENABLED=false
PRIVSHIELD_NER_MODEL=Davlan/xlm-roberta-base-ner-hrl
PRIVSHIELD_NER_DEVICE=0
PRIVSHIELD_NER_THRESHOLD=0.70
