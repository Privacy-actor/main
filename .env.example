WEB_PORT=8080
PRIVSHIELD_APP_ENV=production
PRIVSHIELD_DATABASE_PATH=data/privshield.db
PRIVSHIELD_CORS_ORIGINS=http://localhost:8080

# 正式服务器开启真实 NER；本机无模型演示时可设为 false。
PRIVSHIELD_NER_ENABLED=true
PRIVSHIELD_NER_MODEL=Davlan/xlm-roberta-base-ner-hrl
PRIVSHIELD_NER_DEVICE=-1
PRIVSHIELD_NER_THRESHOLD=0.70

# 语义伪名候选可选使用句向量模型评分。
PRIVSHIELD_SEMANTIC_MODEL_ENABLED=true
PRIVSHIELD_SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
PRIVSHIELD_SEMANTIC_MODEL_DEVICE=-1

# 可选远程知识图谱，默认关闭；失败时自动回退到内置层级与规则推断。
# 开启后会把待查询实体词发送给所配置的服务，只应指向可信内网或受控服务。
PRIVSHIELD_KNOWLEDGE_GRAPH_REMOTE_ENABLED=false
PRIVSHIELD_KNOWLEDGE_GRAPH_CNPROBASE_URL=http://shuyantech.com/api/cnprobase/concept
PRIVSHIELD_KNOWLEDGE_GRAPH_CNDBPEDIA_URL=http://shuyantech.com/api/cndbpedia/avpair
PRIVSHIELD_KNOWLEDGE_GRAPH_TIMEOUT_SECONDS=4
PRIVSHIELD_KNOWLEDGE_GRAPH_CACHE_SECONDS=86400

PRIVSHIELD_LLM_ENABLED=true
# Docker Compose 内置 vLLM 时使用 http://vllm:8000/v1
PRIVSHIELD_LLM_BASE_URL=http://vllm:8000/v1
PRIVSHIELD_LLM_API_KEY=local-token
PRIVSHIELD_LLM_MODEL=Qwen/Qwen3-14B-AWQ
PRIVSHIELD_LLM_TIMEOUT_SECONDS=60
PRIVSHIELD_LLM_MAX_RETRIES=1
PRIVSHIELD_LLM_MAX_ROUTED_SENTENCES=8
PRIVSHIELD_LLM_MAX_CONCURRENCY=2

VLLM_MODEL=Qwen/Qwen3-14B-AWQ
VLLM_SERVED_NAME=Qwen/Qwen3-14B-AWQ
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_NUM_SEQS=8
HUGGING_FACE_HUB_TOKEN=
